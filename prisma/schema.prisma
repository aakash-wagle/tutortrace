generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model UserSession {
  id             String          @id @default(cuid())
  accessToken    String
  refreshToken   String?
  expiresAt      DateTime?
  canvasUserId   String?
  canvasUrl      String?
  displayName    String?
  avatarUrl      String?
  isDemo         Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  flashcardDecks FlashcardDeck[]
}

model FlashcardDeck {
  id          String      @id @default(cuid())
  sessionId   String
  session     UserSession @relation(fields: [sessionId], references: [id])
  title       String
  courseId    String?
  courseName  String?
  sourceType  String      // "module" | "assignment" | "page" | "file" | "manual"
  sourceIds   String      // JSON array of Canvas source IDs
  sourceNames String      // JSON array of source display names
  cardCount   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  cards       Flashcard[]
}

model Flashcard {
  id         String   @id @default(cuid())
  deckId     String
  deck       FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  front      String
  back       String
  hint       String?
  difficulty String   @default("medium") // "easy" | "medium" | "hard"
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
}
