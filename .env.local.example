NEXT_PUBLIC_APP_URL=http://localhost:3000

# Canvas LMS OAuth2
CANVAS_BASE_URL=https://psu.instructure.com
CANVAS_CLIENT_ID=your_canvas_client_id
CANVAS_CLIENT_SECRET=your_canvas_client_secret
CANVAS_REDIRECT_URI=http://localhost:3000/api/auth/canvas/callback

# Session encryption secret (generate with: openssl rand -hex 32)
SESSION_SECRET=change_me_to_a_random_64_char_hex_string_for_production

# Database
# SQLite for local dev:
DATABASE_URL=file:./dev.db
# Postgres for production (e.g. Supabase):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Google Gemini AI (get from https://aistudio.google.com/apikey)
GOOGLE_GEMINI_API_KEY=your_gemini_api_key
