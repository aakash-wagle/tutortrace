NEXT_PUBLIC_APP_URL=http://localhost:3000

# Canvas LMS OAuth2
CANVAS_BASE_URL=https://psu.instructure.com
CANVAS_CLIENT_ID=your_canvas_client_id
CANVAS_CLIENT_SECRET=your_canvas_client_secret
CANVAS_REDIRECT_URI=http://localhost:3000/api/auth/canvas/callback

# Vite SPA (npm run vite:dev) — proxy for Canvas
SPA_ORIGIN=http://localhost:5173
PORT=3001
VITE_CANVAS_PROXY_BASE=http://localhost:3001

# LLM — OpenAI-compatible API (Groq, LiteLLM, OpenRouter, …). VITE_LLM_API_KEY is the only key in the browser;
# other provider keys stay on your gateway or on Groq’s servers.
#
# --- Groq (recommended for speed + simple setup; keys: https://console.groq.com/keys ) ---
# Base URL is always: https://api.groq.com/openai/v1  (CORS works from localhost; no dev proxy needed.)
# Context: production chat models use 131,072 input tokens on Groq (see console.groq.com/docs/models).
# RPM/TPM: free tier is much lower than the “Developer” plan (see console.groq.com/docs/rate-limits).
# Model picks (official model IDs, balance of quality vs speed vs max output — per Groq docs):
#   openai/gpt-oss-20b          — ~1000 tok/s, 131K context, 65K max completion, strong default “balance”
#   llama-3.3-70b-versatile     — ~280 tok/s, 131K context, 32K max completion, best reasoning of this set
#   llama-3.1-8b-instant        — ~560 tok/s, 131K context, 131K max completion, cheapest/fastest for bulk JSON
VITE_LLM_BASE_URL=https://api.groq.com/openai/v1
VITE_LLM_API_KEY=
VITE_LLM_MODEL=openai/gpt-oss-20b
#
# --- Self-hosted LiteLLM instead (optional) ---
# Full URL with http(s). CORS: browser cannot call another origin unless the server allows it.
# VITE_LLM_BASE_URL=http://127.0.0.1:4000/v1
# Dev proxy (no CORS to LiteLLM): LLM_PROXY_TARGET=http://127.0.0.1:4000 and VITE_LLM_BASE_URL=/api/llm/v1

# Delay in ms between generating each chapter (reduces 429 rate limits). Default 7500.
# VITE_CHAPTER_GEN_DELAY_MS=7500

# Max completion tokens for chapter JSON. Default 4096 (fits Groq on-demand TPM; paid tiers can use 8192–32768).
# VITE_LLM_CHAPTER_MAX_TOKENS=2048
# Set to false if your gateway rejects OpenAI json_object for chapter calls:
# VITE_LLM_JSON_CHAPTERS=false

# YouTube Data API v3 (https://console.cloud.google.com/) — optional, for course videos
VITE_YOUTUBE_API_KEY=your_youtube_data_api_key
